{
  "name": "esim-myanmar-entertainment-server",
  "version": "2.0.0",
  "description": "Premium entertainment server with 5G eSIM connectivity across Myanmar and ASEAN",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "export": "next export",
    "deploy": "npm run build && npm run export",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "next": "14.0.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@fluentui/react": "8.118.0",
    "@fluentui/react-icons": "2.0.239",
    "@fluentui/react-components": "9.46.0",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@azure/msal-browser": "3.7.1",
    "@azure/msal-react": "2.0.9",
    "@microsoft/microsoft-graph-toolkit": "3.1.3",
    "@microsoft/microsoft-graph-toolkit-react": "3.1.3",
    "@azure/functions": "4.5.0",
    "@azure/storage-blob": "12.17.0",
    "@azure/cosmos": "4.0.0",
    "@azure/service-bus": "7.9.4",
    "@azure/event-hubs": "5.11.4",
    "@azure/monitor-opentelemetry": "1.0.0",
    "@azure/identity": "4.0.1",
    "@azure/keyvault-secrets": "4.7.0",
    "@azure/app-configuration": "1.5.0",
    "microsoft-cognitiveservices-speech-sdk": "1.34.1",
    "powerbi-client": "2.23.1",
    "powerbi-client-react": "1.4.0",
    "@microsoft/signalr": "8.0.0",
    "framer-motion": "10.16.16",
    "react-intersection-observer": "9.5.3",
    "react-query": "3.39.3",
    "zustand": "4.4.7",
    "date-fns": "2.30.0",
    "clsx": "2.0.0",
    "tailwind-merge": "2.2.0"
  },
  "devDependencies": {
    "@types/node": "20.10.6",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3",
    "eslint": "8.56.0",
    "eslint-config-next": "14.0.4",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "prettier": "3.1.1",
    "tailwindcss": "3.4.0",
    "autoprefixer": "10.4.16",
    "postcss": "8.4.32",
    "jest": "29.7.0",
    "@testing-library/react": "14.1.2",
    "@testing-library/jest-dom": "6.2.0",
    "jest-environment-jsdom": "29.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esimmyanmar/esimmyanmar.github.io.git"
  },
  "keywords": [
    "esim",
    "myanmar",
    "entertainment",
    "5g",
    "streaming",
    "microsoft",
    "azure",
    "power-platform",
    "asean",
    "connectivity"
  ],
  "author": {
    "name": "eSIM Myanmar Company Limited",
    "email": "info@esim.com.mm",
    "url": "https://esim.com.mm"
  },
  "license": "PROPRIETARY",
  "homepage": "https://esim.com.mm",
  "bugs": {
    "url": "https://github.com/esimmyanmar/esimmyanmar.github.io/issues",
    "email": "support@esim.com.mm"
  },
  "funding": {
    "type": "corporate",
    "url": "https://esim.com.mm/investors"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals",
      "@typescript-eslint/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  }
}