{
  "name": "esim-myanmar-entertainment-server",
  "version": "2.0.0",
  "description": "Premium entertainment server with 5G eSIM connectivity across Myanmar and ASEAN",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "export": "next export",
    "deploy": "./deploy.sh",
    "lighthouse": "lighthouse https://esim.com.mm --output=json --output-path=./lighthouse-report.json",
    "security-scan": "npm audit --audit-level=moderate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "production-deploy": "npm run build && npm run deploy"
  },
