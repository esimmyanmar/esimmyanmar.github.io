{
  "name": "esim-myanmar-enterprise-website",
  "version": "1.0.0",
  "description": "Enterprise eSIM company profile and information website (300 pages). Microsoft Stack: Azure Static Web Apps, Power Pages, Microsoft Graph Toolkit, Power Automate, Power BI, Copilot Studio, Dataverse. Zero external dependencies. English, Myanmar, Chinese.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npm run build && npm run deploy:azure",
    "deploy:azure": "az staticwebapp deploy --name esim-myanmar --source ./out",
    "deploy:github": "gh-pages -d out",
    "test": "playwright test",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "audit": "npm audit --audit-level moderate",
    "security": "npm audit --audit-level high"
  },
  "dependencies": {
    "@azure/functions": "^4.5.1",
    "@azure/identity": "^4.0.1",
    "@azure/storage-blob": "^12.17.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/mgt-element": "^3.1.3",
    "@microsoft/mgt-react": "^3.1.3",
    "@microsoft/mgt-sharepoint-provider": "^3.1.3",
    "@microsoft/mgt-msal2-provider": "^3.1.3",
    "@fluentui/react": "^8.118.0",
    "@fluentui/react-components": "^9.47.4",
    "@fluentui/react-icons": "^2.0.239",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.5.4",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "sass": "1.77.8",
    "tailwindcss": "3.4.7",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.40"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "@azure/static-web-apps-cli": "^1.1.9",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "gh-pages": "^6.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esimmyanmar/esimmyanmar.github.io.git"
  },
  "keywords": [
    "esim",
    "myanmar",
    "telecommunications",
    "microsoft",
    "azure",
    "power-platform",
    "company-profile"
  ],
  "author": {
    "name": "eSIM Myanmar Company Limited",
    "email": "info@esim.com.mm",
    "url": "https://esim.com.mm"
  },
  "license": "PROPRIETARY",
  "homepage": "https://esimmyanmar.github.io/",
  "microsoftStack": {
    "azureStaticWebApps": "^1.1.9",
    "azureFunctions": "^4.5.1",
    "powerPages": "latest",
    "microsoftGraphToolkit": "^3.1.3",
    "copilotStudio": "latest",
    "dataverse": "latest",
    "powerAutomate": "latest",
    "powerBI": "latest",
    "fluentUI": "^9.47.4"
  }
}