{
  "name": "esim-myanmar-entertainment-server",
  "version": "2.0.0",
  "description": "Premium entertainment server with 5G eSIM connectivity across Myanmar and ASEAN",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:css": "stylelint \"**/*.css\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lighthouse": "node scripts/lighthouse-test.js",
    "security-scan": "npm audit --audit-level=moderate",
    "accessibility": "node scripts/check-accessibility.js",
    "link-check": "node scripts/check-links.js",
    "validate-html": "node scripts/validate-html.js",
    "optimize-images": "node scripts/optimize-images.js",
    "check-case": "node scripts/check-case.js",
    "scan-no-emoji": "node scripts/scan-no-emoji.js",
    "validate-files": "node scripts/validate-files.js",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "clean": "rm -rf .next out node_modules/.cache",
    "deploy": "npm run build && npm run export",
    "production-deploy": "npm run clean && npm run lint && npm run type-check && npm run build && npm run export"
  },
  "dependencies": {
    "next": "14.0.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@fluentui/react": "8.118.0",
    "@fluentui/react-icons": "2.0.239",
    "@fluentui/react-components": "9.46.0",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@azure/msal-browser": "3.7.1",
    "@azure/msal-react": "2.0.9",
    "@microsoft/signalr": "8.0.0"
  },
  "devDependencies": {
    "@types/node": "20.10.6",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3",
    "eslint": "8.56.0",
    "eslint-config-next": "14.0.4",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "prettier": "3.1.1",
    "tailwindcss": "3.4.0",
    "autoprefixer": "10.4.16",
    "postcss": "8.4.32",
    "jest": "29.7.0",
    "@testing-library/react": "14.1.2",
    "@testing-library/jest-dom": "6.2.0",
    "jest-environment-jsdom": "29.7.0",
    "stylelint": "16.1.0",
    "stylelint-config-standard": "36.0.0",
    "husky": "8.0.3",
    "lint-staged": "15.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{css,scss}": ["stylelint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esimmyanmar/esimmyanmar.github.io.git"
  },
  "keywords": ["esim", "myanmar", "entertainment", "5g", "microsoft", "azure"],
  "author": {
    "name": "eSIM Myanmar Company Limited",
    "email": "info@esim.com.mm",
    "url": "https://esim.com.mm"
  },
  "license": "PROPRIETARY",
  "homepage": "https://esim.com.mm"
}