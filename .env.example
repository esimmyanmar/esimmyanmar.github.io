# eSIM Myanmar Environment Variables
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://esimmyanmar.github.io
NEXT_PUBLIC_SITE_NAME=eSIM Myanmar
NEXT_PUBLIC_TWITTER_HANDLE=@eSIMMyanmar

# Security Configuration
NEXT_PUBLIC_SECURITY_ENABLED=true
NEXT_PUBLIC_CONTENT_PROTECTION=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=info@esim.com.mm
NEXT_PUBLIC_CONTACT_PHONE=+95-9650000172

# Company Information
NEXT_PUBLIC_COMPANY_NAME=ESIM MYANMAR COMPANY LIMITED
NEXT_PUBLIC_COMPANY_ADDRESS=Myanmar

# NetLync EaaS Configuration
NEXT_PUBLIC_NETLYNC_ENDPOINT=
NEXT_PUBLIC_NETLYNC_API_VERSION=v2.0

# Development
NODE_ENV=production