### Example environment variables for local development and CI
# Copy to `.env.local` and fill the real secrets — DO NOT commit secrets to git.

# Azure / Microsoft
NEXT_PUBLIC_AZURE_CLIENT_ID=your-azure-client-id
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
NEXT_PUBLIC_MICROSOFT_TENANT_ID=your-microsoft-tenant-id

# SharePoint / Dataverse
NEXT_PUBLIC_SHAREPOINT_SITE=https://your-tenant.sharepoint.com/sites/your-site
NEXT_PUBLIC_DATAVERSE_URL=https://your-environment.crm.dynamics.com

# Copilot / Power BI
NEXT_PUBLIC_COPILOT_BOT_ID=your-copilot-bot-id
NEXT_PUBLIC_POWER_BI_WORKSPACE=your-powerbi-workspace-id

# Base URL used by Playwright and local testing
BASE_URL=http://localhost:3000
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
NEXT_PUBLIC_MICROSOFT_TENANT_ID=your-microsoft-tenant-id
NEXT_PUBLIC_SHAREPOINT_SITE=https://esimmyanmar.sharepoint.com
NEXT_PUBLIC_DATAVERSE_URL=https://prod-esim-myanmar.crm5.dynamics.com
NEXT_PUBLIC_COPILOT_BOT_ID=esim-myanmar-assistant
NEXT_PUBLIC_POWER_BI_WORKSPACE=your-power-bi-workspace-id
NEXT_PUBLIC_COPILOT_TOKEN=your-copilot-direct-line-token
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
SHAREPOINT_ACCESS_TOKEN=your-sharepoint-access-token
POWER_BI_ACCESS_TOKEN=your-power-bi-access-token
AZURE_STATIC_WEB_APPS_API_TOKEN=your-azure-static-web-apps-token
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
TEAMS_WEBHOOK_URL=your-teams-webhook-url
GSMA_API_KEY=your-gsma-api-key